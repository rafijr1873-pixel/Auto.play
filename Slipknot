-- UTILITY FUNCTIONS
------------------------------------------------------------
local function sendKeyPress(keyCode, pressed)
    local ok = pcall(function()
        VirtualInputManager:SendKeyEvent(pressed, keyCode, false, game)
    end)
    if not ok then
        pcall(function()
            if pressed then keypress(keyCode) else keyrelease(keyCode) end
        end)
    end
end

local function hitDrums(drumNames)
    if not drumNames or #drumNames == 0 then return end
    for _, name in ipairs(drumNames) do
        local kc = KEYS[name]
        if kc then sendKeyPress(kc, true) end
    end
    task.wait(CONFIG.keyHoldTime)
    for _, name in ipairs(drumNames) do
        local kc = KEYS[name]
        if kc then sendKeyPress(kc, false) end
    end
end

local function humanize()
    return math.random() * CONFIG.humanizeMax
end

