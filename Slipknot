-- KEYBOARD SHORTCUTS (masih bisa pakai keyboard)
------------------------------------------------------------
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    -- P = Toggle Pattern
    if input.KeyCode == Enum.KeyCode.P then
        if STATE.isPlaying and STATE.mode == "pattern" then
            stopPlaying()
        else
            if STATE.isPlaying then stopPlaying() end
            STATE.mode = "pattern"
            STATE.isPlaying = true
            updateGUI()
            task.spawn(playPatternLoop)
        end
    end

    -- O = Toggle Eyeless
    if input.KeyCode == Enum.KeyCode.O then
        if STATE.isPlaying and STATE.mode == "eyeless" then
            stopPlaying()
        else
            if STATE.isPlaying then stopPlaying() end
            STATE.mode = "eyeless"
            STATE.isPlaying = true
            updateGUI()
            task.spawn(playEyeless)
        end
    end

    -- [ = Next Pattern
    if input.KeyCode == Enum.KeyCode.LeftBracket then
        STATE.patternIndex = (STATE.patternIndex % #PATTERNS) + 1
        updateGUI()
    end

    -- ] = BPM Up
    if input.KeyCode == Enum.KeyCode.RightBracket then
        if STATE.isPlaying and STATE.mode == "eyeless" then
            CONFIG.eyelessBPM = math.min(CONFIG.eyelessBPM + 5, 220)
        else
            CONFIG.patternBPM = math.min(CONFIG.patternBPM + 5, 300)
        end
        updateGUI()
    end

    -- ' = BPM Down
    if input.KeyCode == Enum.KeyCode.Quote then
        if STATE.isPlaying and STATE.mode == "eyeless" then
            CONFIG.eyelessBPM = math.max(CONFIG.eyelessBPM - 5, 60)
        else
            CONFIG.patternBPM = math.max(CONFIG.patternBPM - 5, 40)
        end
        updateGUI()
    end
end)

