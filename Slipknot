local function updateGUI()
    -- BPM Display
    local currentBPM = (STATE.mode == "eyeless" and STATE.isPlaying)
        and CONFIG.eyelessBPM or CONFIG.patternBPM
    BPMDisplay.Text = tostring(currentBPM)

    -- Status
    if STATE.isPlaying then
        StatusDot.BackgroundColor3 = COLORS.green
        if STATE.mode == "pattern" then
            local pat = PATTERNS[STATE.patternIndex]
            StatusLabel.Text = "▶ Playing: " .. pat.icon .. " " .. pat.name
            StatusInfo.Text = "Pattern Loop • " .. CONFIG.patternBPM .. " BPM"
            PatternPlayBtn.Text = "⏹  STOP PATTERN"
            PatternPlayBtn.BackgroundColor3 = COLORS.accent
            EyelessPlayBtn.Text = "▶  PLAY EYELESS"
            EyelessPlayBtn.BackgroundColor3 = COLORS.accent
            EyelessSectionLabel.Text = ""
            ProgressLabel.Text = ""
            ProgressFill.Size = UDim2.new(0, 0, 1, 0)
        else
            StatusLabel.Text = "▶ EYELESS"
            StatusInfo.Text = STATE.currentSection .. " • " .. CONFIG.eyelessBPM .. " BPM"
            EyelessPlayBtn.Text = "⏹  STOP EYELESS"
            EyelessPlayBtn.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
            PatternPlayBtn.Text = "▶  PLAY PATTERN"
            PatternPlayBtn.BackgroundColor3 = COLORS.green
            EyelessSectionLabel.Text = STATE.currentSection

            -- Progress
            if STATE.totalBars > 0 then
                local progress = STATE.barCount / STATE.totalBars
                ProgressFill.Size = UDim2.new(math.clamp(progress, 0, 1), 0, 1, 0)
                ProgressLabel.Text = string.format(
                    "Bar %d / %d (%.0f%%)",
                    STATE.barCount, STATE.totalBars,
                    progress * 100
                )
            end
        end
    else
        StatusDot.BackgroundColor3 = COLORS.accent
        StatusLabel.Text = "⏸ Stopped"
        StatusInfo.Text = "Tekan tombol di bawah untuk mulai"
        PatternPlayBtn.Text = "▶  PLAY PATTERN"
        PatternPlayBtn.BackgroundColor3 = COLORS.green
        EyelessPlayBtn.Text = "▶  PLAY EYELESS"
        EyelessPlayBtn.BackgroundColor3 = COLORS.accent
        EyelessSectionLabel.Text = ""
        ProgressLabel.Text = ""
        ProgressFill.Size = UDim2.new(0, 0, 1, 0)

        -- Reset beat dots
        for _, dot in ipairs(beatDots) do
            dot.BackgroundColor3 = COLORS.bgDark
        end
    end

    -- Pattern buttons highlight
    for i, btn in ipairs(patternButtons) do
        if i == STATE.patternIndex then
            btn.BackgroundColor3 = COLORS.accent
            btn.TextColor3 = COLORS.white
        else
            btn.BackgroundColor3 = COLORS.bgDark
            btn.TextColor3 = COLORS.textSecondary
        end
    end

    -- Eyeless info
    EyelessInfo.Text = CONFIG.eyelessBPM .. " BPM • "
        .. totalEyelessBars .. " bars • Full song with loop"
end

-- Beat dot animation
local function lightBeatDot(stepIndex, maxSteps)
    local dotIndex = ((stepIndex - 1) % 16) + 1
    for i, dot in ipairs(beatDots) do
        if i == dotIndex then
            dot.BackgroundColor3 = COLORS.accent
            -- Tween fade
            task.spawn(function()
                task.wait(0.15)
                if beatDots[i] then
                    tweenColor(dot, "BackgroundColor3", COLORS.bgDark, 0.3)
                end
            end)
        end
    end
end

------------------------------------------------------------
-- PLAY FUNCTIONS
------------------------------------------------------------
local function stopPlaying()
    STATE.isPlaying = false
    task.wait(0.2)
    updateGUI()
end

-- Pattern Loop
local function playPatternLoop()
    while STATE.isPlaying and STATE.mode == "pattern" do
        local eighthNote = 60 / CONFIG.patternBPM / 2
        local pattern = PATTERNS[STATE.patternIndex]

        for i = 1, #pattern.steps do
            if not STATE.isPlaying or STATE.mode ~= "pattern" then return end

            STATE.currentStep = i
            hitDrums(pattern.steps[i])
            lightBeatDot(i, #pattern.steps)

            task.wait(math.max(eighthNote + humanize(), 0.05))
        end
    end
end

-- Eyeless Song
local function playEyeless()
    STATE.totalBars = totalEyelessBars
    STATE.barCount = 0

    while STATE.isPlaying and STATE.mode == "eyeless" do
        STATE.barCount = 0

        for structIdx, entry in ipairs(EYELESS_STRUCTURE) do
            if not STATE.isPlaying or STATE.mode ~= "eyeless" then return end

            local sectionKey = entry[1]
            local bars       = entry[2]
            local section    = EYELESS_SECTIONS[sectionKey]

            if not section then continue end

            STATE.currentSection = section.icon .. " " .. section.name
            updateGUI()

            for bar = 1, bars do
                if not STATE.isPlaying or STATE.mode ~= "eyeless" then return end
                STATE.barCount = STATE.barCount + 1

                for step = 1, #section.steps do
                    if not STATE.isPlaying or STATE.mode ~= "eyeless" then return end

                    local sixteenthNote = 60 / CONFIG.eyelessBPM / 4
                    STATE.currentStep = step

                    hitDrums(section.steps[step])
                    lightBeatDot(step, #section.steps)

                    -- Update progress setiap 4 steps
                    if step % 4 == 0 then
                        updateGUI()
                    end

                    task.wait(math.max(sixteenthNote + humanize(), 0.04))
                end
            end
        end

        -- Song selesai → loop
        print("🔄 EYELESS selesai — loop dari awal...")
    end
end

