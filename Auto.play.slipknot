-- ── Status Label ──
local stat = Instance.new("TextLabel")
stat.Size = UDim2.new(1, -8, 0, 16)
stat.Position = UDim2.new(0, 4, 0, 60)
stat.BackgroundTransparency = 1
stat.Text = "⏹ 120BPM · Bar:0"
stat.TextColor3 = Color3.fromRGB(130, 130, 130)
stat.TextSize = 10
stat.Font = Enum.Font.Gotham
stat.Parent = fr

-- ══════════════════════════════════════
-- GUI REFRESH
-- ══════════════════════════════════════
local function refreshGUI()
    local p = PATTERNS[pIdx]
    patBtn.Text = p.name .. " ▸"

    if _G._AutoDrumActive then
        togBtn.Text = "⏸ STOP"
        togBtn.BackgroundColor3 = Color3.fromRGB(180, 30, 30)
        stat.TextColor3 = Color3.fromRGB(80, 255, 90)
    else
        togBtn.Text = "▶ PLAY"
        togBtn.BackgroundColor3 = Color3.fromRGB(0, 155, 50)
        stat.TextColor3 = Color3.fromRGB(130, 130, 130)
    end

    stat.Text = (_G._AutoDrumActive and "▶ " or "⏹ ")
        .. p.bpm .. "BPM · Bar:" .. barCount
end

-- Live bar counter update
task.spawn(function()
    while gui and gui.Parent do
        if _G._AutoDrumActive then
            pcall(function()
                local p = PATTERNS[pIdx]
                stat.Text = "▶ " .. p.bpm .. "BPM · Bar:" .. barCount
            end)
        end
        task.wait(0.25)
    end
end)

-- ══════════════════════════════════════
-- TOGGLE & PATTERN SWITCH
-- ══════════════════════════════════════
local function toggle()
    if _G._AutoDrumActive then
        stopDrum()
    else
        startDrum()
    end
    refreshGUI()
end

local function cyclePattern()
    local wasPlaying = _G._AutoDrumActive
    if wasPlaying then
        stopDrum()
        task.wait(0.15)
    end
    pIdx = (pIdx % #PATTERNS) + 1
    barCount = 0
    refreshGUI()
    if wasPlaying then
        startDrum()
        refreshGUI()
    end
end

-- ══════════════════════════════════════
-- INPUT CONNECTIONS
-- ══════════════════════════════════════
togBtn.MouseButton1Click:Connect(toggle)
patBtn.MouseButton1Click:Connect(cyclePattern)

local keyConn = UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.P then
        toggle()
    end
end)

closeBtn.MouseButton1Click:Connect(function()
    stopDrum()
    task.wait(0.1)
    if gui then gui:Destroy() end
    if keyConn then keyConn:Disconnect() end
    _G._AutoDrumActive = nil
    print("[AutoDrum] 🗑️ Unloaded.")
end)

-- ══════════════════════════════════════
-- STARTUP
-- ══════════════════════════════════════
refreshGUI()
pcall(function()
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "🥁 Auto Drum v2",
        Text = "Tap PLAY or press P · Rock / Eyeless",
        Duration = 4,
    })
end)
print("[AutoDrum] ✅ Loaded — Rock 120BPM | Eyeless 142BPM")
