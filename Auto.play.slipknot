    ["CHORUS 2★"] = Color3.fromRGB(255,80,20),
    ["BREAK ⬛"]  = Color3.fromRGB(180,80,255),
    ["BLAST!!"]   = Color3.fromRGB(255,40,40),
    ["FILL ↓"]    = Color3.fromRGB(255,220,60),
    ["INTRO"]     = Color3.fromRGB(160,160,160),
    ["→ VERSE"]   = Color3.fromRGB(120,255,120),
    ["Rock"]      = Color3.fromRGB(100,220,130),
    ["IDLE"]      = Color3.fromRGB(120,120,120),
}

local function refresh()
    local p = PATS[pIdx]
    pb.Text = p.name .. " ▸"
    if _G._AD then
        tb.Text = "⏸ STOP"
        tb.BackgroundColor3 = Color3.fromRGB(170,25,25)
        s1.Text = secN .. " · " .. p.bpm .. " BPM"
        s1.TextColor3 = secColors[secN] or Color3.fromRGB(80,255,90)
        s2.Text = "Bar: " .. barN .. " │ 🟢 Playing"
        s2.TextColor3 = Color3.fromRGB(60,180,60)
    else
        tb.Text = "▶ PLAY"
        tb.BackgroundColor3 = Color3.fromRGB(0,150,45)
        s1.Text = "⏹ " .. p.name .. " · " .. p.bpm .. " BPM"
        s1.TextColor3 = Color3.fromRGB(120,120,120)
        s2.Text = "Bar: " .. barN .. " │ tap ▶ or press P"
        s2.TextColor3 = Color3.fromRGB(90,90,100)
    end
end

-- Live updater
task.spawn(function()
    while gui and gui.Parent do
        pcall(refresh)
        task.wait(0.2)
    end
end)

-- ═══════════════════════════════════════
-- §13  TOGGLE & PATTERN SWITCH
-- ═══════════════════════════════════════
local function toggle()
    if _G._AD then stop() else go() end
    refresh()
end

local function cycle()
    local was = _G._AD
    if was then stop(); task.wait(0.15) end
    pIdx = pIdx % #PATS + 1
    barN = 0; introD = true; secN = "IDLE"
    refresh()
    if was then go(); refresh() end
end

-- ═══════════════════════════════════════
-- §14  CONNECTIONS
-- ═══════════════════════════════════════
tb.MouseButton1Click:Connect(toggle)
pb.MouseButton1Click:Connect(cycle)

local kc = UIS.InputBegan:Connect(function(i, gp)
    if gp then return end
    if i.KeyCode == Enum.KeyCode.P then toggle() end
end)

cb.MouseButton1Click:Connect(function()
    stop(); task.wait(0.1)
    if gui then gui:Destroy() end
    if kc then kc:Disconnect() end
    _G._AD = nil
end)

-- ═══════════════════════════════════════
-- §15  STARTUP
-- ═══════════════════════════════════════
refresh()
pcall(function()
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "🥁 Auto Drum v3 Loaded",
        Text  = "Rock 120 │ Eyeless 142 — Tap ▶ or P",
        Duration = 4,
    })
end)
print("🥁 AutoDrum v3 ✅ │ Rock 120BPM │ Eyeless 142BPM │ Press P or tap ▶")
