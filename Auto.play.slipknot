local togBtn = Instance.new("TextButton")
togBtn.Size = UDim2.new(0, 80, 0, 30)
togBtn.Position = UDim2.new(0, 6, 0, 24)
togBtn.BackgroundColor3 = Color3.fromRGB(0, 155, 50)
togBtn.Text = "▶ PLAY"
togBtn.TextColor3 = Color3.new(1, 1, 1)
togBtn.TextSize = 13
togBtn.Font = Enum.Font.GothamBold
