    { "intro2",     4 },     -- 4 bar kick building
    { "introCrash", 1 },     -- 1 bar snare roll → crash

    -----------------------------------------
    -- VERSE 1  (8 bars, ~13 detik)
    -----------------------------------------
    { "verse",      6 },     -- 6 bar main groove
    { "verse2",     1 },     -- 1 bar heavy variation
    { "fill",       1 },     -- 1 bar tom fill

    -----------------------------------------
    -- CHORUS 1  (8 bars, ~13 detik)
    -----------------------------------------
    { "chorus",     6 },     -- 6 bar full power
    { "chorus2",    1 },     -- 1 bar chorus ending
    { "fill2",      1 },     -- 1 bar aggressive fill

    -----------------------------------------
    -- VERSE 2  (8 bars, ~13 detik)
    -----------------------------------------
    { "verse",      5 },     -- 5 bar groove
    { "verse2",     1 },     -- 1 bar heavy
    { "prechorus",  2 },     -- 2 bar pre-chorus build

    -----------------------------------------
    -- CHORUS 2  (8 bars, ~13 detik)
    -----------------------------------------
    { "fill",       1 },     -- 1 bar fill into chorus
    { "chorus",     5 },     -- 5 bar chorus
    { "chorus2",    2 },     -- 2 bar chorus ending

    -----------------------------------------
    -- BRIDGE / BREAKDOWN  (8 bars, ~13 detik)
    -----------------------------------------
    { "bridge",     4 },     -- 4 bar breakdown
    { "bridge2",    3 },     -- 3 bar heavy breakdown
    { "fill2",      1 },     -- 1 bar fill out

    -----------------------------------------
    -- FINAL CHORUS  (8 bars, ~13 detik)
    -----------------------------------------
    { "chorus",     5 },     -- 5 bar final chorus
    { "chorus2",    2 },     -- 2 bar chorus ending
    { "fill",       1 },     -- 1 bar fill

    -----------------------------------------
    -- OUTRO  (4 bars, ~7 detik)
    -----------------------------------------
    { "outro",      4 },     -- 4 bar outro → loop
}

-- ══════════════════════════════════════════
--  PLAY EYELESS FUNCTION
-- ══════════════════════════════════════════
local function playEyeless()
    print("\n🎵 ═══ SLIPKNOT — EYELESS ═══")
    print("   Tempo: " .. EYELESS.bpm .. " BPM")
    print("   Tekan O untuk stop\n")

    while isPlaying and mode == "eyeless" do
        currentSection = ""

        for structIdx, entry in ipairs(EYELESS.structure) do
            if not isPlaying or mode ~= "eyeless" then return end

            local sectionKey = entry[1]
            local bars       = entry[2]
            local section    = EYELESS.sections[sectionKey]

            if not section then
                warn("Section tidak ditemukan: " .. sectionKey)
                continue
            end

            -- Print pergantian section
            if currentSection ~= section.name then
                currentSection = section.name
                print(string.format(
                    "  ♪  %s  (%d bar%s)  [%d/%d]",
                    section.name,
                    bars,
                    bars > 1 and "s" or "",
                    structIdx,
                    #EYELESS.structure
                ))
            end

            -- Mainkan section sebanyak 'bars' kali
            for bar = 1, bars do
                if not isPlaying or mode ~= "eyeless" then return end

                for step = 1, #section.steps do
                    if not isPlaying or mode ~= "eyeless" then return end

                    -- Hitung timing per step (recalc supaya BPM change real-time)
                    local sixteenthNote = 60 / EYELESS.bpm / 4

                    hitDrums(section.steps[step])
                    task.wait(math.max(sixteenthNote + humanize(), 0.04))
                end
            end
        end

        -- Lagu selesai → loop
        print("\n  🔄 EYELESS selesai — loop dari awal...\n")
    end
end

------------------------------------------------------------
--
--   INPUT HANDLER
--
------------------------------------------------------------
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    -- ═══ P : Toggle Pattern Loop ═══
    if input.KeyCode == TOGGLE_KEY then
        if isPlaying then
            local wasMode = mode
            stopPlaying()
            if wasMode == "pattern" then
                print("🥁 Pattern Loop: OFF")
                return
            end
        end
        mode = "pattern"
        isPlaying = true
        local pat = PATTERNS[patternIndex]
        print(string.format(
            "🥁 Pattern Loop: ON  |  %s  |  BPM: %d",
            pat.name, BPM
        ))
        task.spawn(playPatternLoop)
        return
    end

    -- ═══ O : Toggle Eyeless Song ═══
    if input.KeyCode == SONG_KEY then
        if isPlaying then
            local wasMode = mode
            stopPlaying()
            if wasMode == "eyeless" then
                currentSection = ""
                print("🎵 EYELESS: OFF")
                return
            end
        end
        mode = "eyeless"
        isPlaying = true
        currentSection = ""
        task.spawn(playEyeless)
        return
    end

    -- ═══ [ : Ganti Pattern ═══
    if input.KeyCode == SWITCH_KEY then
        patternIndex = (patternIndex % #PATTERNS) + 1
        local pat = PATTERNS[patternIndex]
        print(string.format("🔄 Pattern → %d. %s", patternIndex, pat.name))
        return
    end

    -- ═══ ] : BPM Naik ═══
    if input.KeyCode == BPM_UP_KEY then
        if isPlaying and mode == "eyeless" then
            EYELESS.bpm = math.min(EYELESS.bpm + 5, 220)
            print("⏫ Eyeless BPM: " .. EYELESS.bpm)
        else
            BPM = math.min(BPM + 10, 300)
            print("⏫ Pattern BPM: " .. BPM)
        end
        return
    end

    -- ═══ ' : BPM Turun ═══
    if input.KeyCode == BPM_DOWN_KEY then
        if isPlaying and mode == "eyeless" then
            EYELESS.bpm = math.max(EYELESS.bpm - 5, 80)
            print("⏬ Eyeless BPM: " .. EYELESS.bpm)
        else
            BPM = math.max(BPM - 10, 40)
            print("⏬ Pattern BPM: " .. BPM)
        end
        return
    end
end)

------------------------------------------------------------
-- SAFETY : Lepas semua saat karakter hilang
------------------------------------------------------------
game:GetService("Players").LocalPlayer.CharacterRemoving:Connect(function()
    isPlaying = false
    currentSection = ""
end)

