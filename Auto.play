--[[
╔═══════════════════════════════════════════════════════╗
║   VIRTUAL DRUMS AUTO PLAYER                          ║
║   + SLIPKNOT — EYELESS (Full Song)                   ║
║   Game: Virtual Drums (ID: 6831290123)               ║
║                                                       ║
║   P    →  Start / Stop pattern loop                   ║
║   O    →  Start / Stop Eyeless song                   ║
║   [    →  Ganti pattern (mode pattern loop)           ║
║   ]    →  BPM + (5 eyeless / 10 pattern)              ║
║   '    →  BPM - (5 eyeless / 10 pattern)              ║
╚═══════════════════════════════════════════════════════╝
]]

------------------------------------------------------------
-- SERVICES
------------------------------------------------------------
local VirtualInputManager = game:GetService("VirtualInputManager")
local UserInputService    = game:GetService("UserInputService")

------------------------------------------------------------
-- KONFIGURASI UTAMA
------------------------------------------------------------
local BPM            = 120          -- BPM untuk pattern loop
local HUMANIZE_MAX   = 0.020        -- random delay max (detik)
local KEY_HOLD_TIME  = 0.025        -- durasi tombol ditahan

-- Tombol kontrol
local TOGGLE_KEY   = Enum.KeyCode.P              -- pattern loop
local SONG_KEY     = Enum.KeyCode.O              -- eyeless song
local SWITCH_KEY   = Enum.KeyCode.LeftBracket    -- [
local BPM_UP_KEY   = Enum.KeyCode.RightBracket   -- ]
local BPM_DOWN_KEY = Enum.KeyCode.Quote           -- '

------------------------------------------------------------
-- KEY MAPPING DRUM
-- ┌──────────────────────────────────────────────┐
-- │  SESUAIKAN DENGAN KONTROL IN-GAME!           │
-- │  Settings game → lihat keybind → ubah sini   │
-- └──────────────────────────────────────────────┘
------------------------------------------------------------
local KEYS = {
    kick      = Enum.KeyCode.Z,
    snare     = Enum.KeyCode.X,
    hihat     = Enum.KeyCode.C,
    hihatOpen = Enum.KeyCode.V,
    tom1      = Enum.KeyCode.J,
    tom2      = Enum.KeyCode.K,
    floorTom  = Enum.KeyCode.L,
    crash     = Enum.KeyCode.Semicolon,
    ride      = Enum.KeyCode.B,
}

------------------------------------------------------------
-- STATE VARIABLES
------------------------------------------------------------
local isPlaying      = false
local mode           = "pattern"   -- "pattern" | "eyeless"
local patternIndex   = 1
local currentSection = ""

------------------------------------------------------------
-- UTILITY FUNCTIONS
------------------------------------------------------------
local function sendKeyPress(keyCode, pressed)
    local ok = pcall(function()
        VirtualInputManager:SendKeyEvent(pressed, keyCode, false, game)
    end)
    if not ok then
        pcall(function()
            if pressed then keypress(keyCode) else keyrelease(keyCode) end
        end)
    end
end

local function hitDrums(drumNames)
    if not drumNames or #drumNames == 0 then return end
    for _, name in ipairs(drumNames) do
        local kc = KEYS[name]
        if kc then sendKeyPress(kc, true) end
    end
    task.wait(KEY_HOLD_TIME)
    for _, name in ipairs(drumNames) do
        local kc = KEYS[name]
        if kc then sendKeyPress(kc, false) end
    end
end

local function humanize()
    return math.random() * HUMANIZE_MAX
end

local function stopPlaying()
    isPlaying = false
    task.wait(0.2)
end

------------------------------------------------------------
--
--   BAGIAN 1 :  PATTERN LOOP MODE
--   (original 7 pattern, 8th-note resolution)
--
------------------------------------------------------------
local PATTERNS = {
    [1] = {
        name = "Simple Rock",
        steps = {
            {"kick","hihat"},  {"hihat"},
            {"snare","hihat"}, {"hihat"},
            {"kick","hihat"},  {"hihat"},
            {"snare","hihat"}, {"hihat"},
        }
    },
    [2] = {
        name = "Driving Rock",
        steps = {
            {"kick","hihat"},  {"hihat"},
            {"snare","hihat"}, {"hihat"},
            {"kick","hihat"},  {"kick","hihat"},
            {"snare","hihat"}, {"hihat"},
        }
    },
    [3] = {
        name = "Disco",
        steps = {
            {"kick","hihat"},            {"hihat"},
            {"kick","snare","hihat"},    {"hihat"},
            {"kick","hihat"},            {"hihat"},
            {"kick","snare","hihat"},    {"hihat"},
        }
    },
    [4] = {
        name = "Half-Time",
        steps = {
            {"kick","hihat"},  {"hihat"},
            {"hihat"},         {"hihat"},
            {"snare","hihat"}, {"hihat"},
            {"hihat"},         {"kick","hihat"},
        }
    },
    [5] = {
        name = "Ride Groove",
        steps = {
            {"kick","ride"},  {"hihat"},
            {"snare","ride"}, {"hihat"},
            {"kick","ride"},  {"kick","hihat"},
            {"snare","ride"}, {"hihat"},
        }
    },
    [6] = {
        name = "Tom Fill",
        steps = {
            {"snare"},   {"snare"},
            {"tom1"},    {"tom1"},
            {"tom2"},    {"tom2"},
            {"floorTom"},{"floorTom","crash"},
        }
    },
    [7] = {
        name = "Blast Beat",
        steps = {
            {"kick","hihat"},  {"snare","hihat"},
            {"kick","hihat"},  {"snare","hihat"},
            {"kick","hihat"},  {"snare","hihat"},
            {"kick","hihat"},  {"snare","hihat"},
        }
    },
}

local function playPatternLoop()
    while isPlaying and mode == "pattern" do
        local eighthNote = 60 / BPM / 2
        local pattern = PATTERNS[patternIndex]
        for i = 1, #pattern.steps do
            if not isPlaying or mode ~= "pattern" then return end
            hitDrums(pattern.steps[i])
            task.wait(math.max(eighthNote + humanize(), 0.05))
        end
    end
end

